# PromptChain CLI Environment Variables
# Copy this file to .env and add your API keys

# Required for integration tests (T034-T035) and CLI operation
# The default model used in router mode is openai/gpt-4o-mini (fast, cost-effective)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic Claude models
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Google Gemini models
GOOGLE_API_KEY=your_google_key_here

# Optional: Ollama (local models - no API key needed)
# Just install Ollama and start the server: ollama serve
