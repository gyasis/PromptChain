# Backend Configuration
# Copy this to .env and update values as needed

# Server Configuration
RESEARCH_AGENT_HOST=0.0.0.0
RESEARCH_AGENT_PORT=8078
RESEARCH_AGENT_LOG_LEVEL=info

# CORS Origins (comma-separated for additional origins)
# RESEARCH_AGENT_CORS_ORIGINS=["http://localhost:5173","http://localhost:8078"]

# Session Management
RESEARCH_AGENT_SESSIONS_DIR=./research_output
RESEARCH_AGENT_MAX_ACTIVE_SESSIONS=10

# Authentication (set to true to enable)
RESEARCH_AGENT_AUTH_ENABLED=false
# RESEARCH_AGENT_JWT_SECRET_KEY=your-secret-key-here

# Debug Mode
RESEARCH_AGENT_DEBUG=false

# Rate Limiting
RESEARCH_AGENT_RATE_LIMIT_ENABLED=false
RESEARCH_AGENT_RATE_LIMIT_REQUESTS=100
RESEARCH_AGENT_RATE_LIMIT_PERIOD=60