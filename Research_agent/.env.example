# Research Agent Environment Configuration
# Copy this file to .env and fill in your API keys

# ===============================================
# LLM API Keys
# ===============================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Cohere
COHERE_API_KEY=your_cohere_api_key_here

# ===============================================
# Academic API Keys
# ===============================================

# ArXiv (no key needed, but set rate limits)
ARXIV_RATE_LIMIT=10  # requests per second

# PubMed (NCBI Entrez API)
PUBMED_EMAIL=your_email@domain.com
PUBMED_API_KEY=your_ncbi_api_key_here  # Optional but recommended
PUBMED_RATE_LIMIT=10  # requests per second

# Sci-Hub MCP Server Configuration
SCIHUB_MCP_ENABLED=true
SCIHUB_TIMEOUT=120  # seconds

# ===============================================
# RAG System Configuration
# ===============================================

# Default RAG mode: cloud, ollama, or hybrid
RAG_MODE=ollama

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=bge-m3:latest

# ===============================================
# Vector Store Configuration
# ===============================================

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chromadb
CHROMA_COLLECTION_NAME=research_papers

# ===============================================
# Caching Configuration
# ===============================================

# Redis (optional, for distributed caching)
REDIS_URL=redis://localhost:6379
REDIS_TTL=86400  # 24 hours

# Disk Cache
CACHE_DIR=./data/cache
CACHE_SIZE_MB=1000  # Max cache size in MB

# ===============================================
# Literature Search Configuration
# ===============================================

# Search Configuration
LITERATURE_CACHE_TTL=86400  # 24 hours
LITERATURE_CACHE_SIZE=1000  # Max cached items
MAX_SEARCH_RESULTS=20
SIMILARITY_THRESHOLD=0.7
NOVELTY_THRESHOLD=0.8

# Rate Limiting
SEMANTIC_SCHOLAR_RATE_LIMIT=100  # Requests per minute
OPENALEX_RATE_LIMIT=50  # Requests per minute

# ===============================================
# Web Interface Configuration
# ===============================================

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Chainlit
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8001
CHAINLIT_AUTH_SECRET=your_secret_key_here

# ===============================================
# Database Configuration
# ===============================================

# SQLite (for conversation history)
SQLITE_DB_PATH=./data/research_sessions.db
SQLITE_TIMEOUT=30

# ===============================================
# Logging Configuration
# ===============================================

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE_MAX_BYTES=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5

# ===============================================
# MCP Server Configuration
# ===============================================

# Enable MCP servers
ENABLE_MCP_SERVERS=true

# Context7 MCP
CONTEXT7_ENABLED=true

# Gemini MCP
GEMINI_MCP_ENABLED=true

# Git MCP
GIT_MCP_ENABLED=true

# ===============================================
# Performance Configuration
# ===============================================

# Async Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=120  # seconds
BATCH_SIZE=5

# Memory Management
MAX_MEMORY_MB=4096
MAX_TOKENS_PER_REQUEST=8000

# ===============================================
# Security Configuration
# ===============================================

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# API Security
API_KEY_ENABLED=false
API_KEY=your_api_key_here

# ===============================================
# Development Settings
# ===============================================

# Debug Mode
DEBUG=false
TESTING=false

# Hot Reload
ENABLE_HOT_RELOAD=true

# Mock Mode (for testing without real APIs)
MOCK_MODE=false