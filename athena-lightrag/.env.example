# Environment variables for Athena LightRAG MCP Server
# Copy this to .env and fill in your actual values

# OpenAI API key for LightRAG operations and PromptChain
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API key for PromptChain multi-model support
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LightRAG working directory (defaults to ./athena_lightrag_db)
LIGHTRAG_WORKING_DIR=./athena_lightrag_db

# MCP Server configuration
MCP_SERVER_NAME=athena-lightrag
MCP_SERVER_VERSION=0.1.0

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FILE=athena_lightrag.log

# Optional: Performance tuning
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30