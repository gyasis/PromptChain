# Environment variables needed for the HybridRAG system
# Copy this to .env and fill in your actual values

# OpenAI API key for LightRAG operations
OPENAI_API_KEY=your_openai_api_key_here

# DeepLake configuration (if using cloud-hosted DeepLake)
ACTIVELOOP_TOKEN=your_activeloop_token_here
ACTIVELOOP_USERNAME=your_activeloop_username_here

# Optional: DeepLake local storage path
# DEEPLAKE_PATH=/path/to/your/deeplake/storage

# Optional: LightRAG working directory
# LIGHTRAG_WORKING_DIR=./athena_lightrag_db