{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptchain.io/schemas/agent-config.json",
  "title": "Agent Configuration",
  "description": "Schema for individual agent configuration within AgentChain orchestrator",
  "type": "object",
  "required": ["name", "model", "description", "instruction_chain"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{1,50}$",
      "description": "Unique agent identifier (alphanumeric, underscore, dash; 1-50 chars)"
    },
    "model": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9/_.-]+$",
      "description": "LiteLLM model identifier (e.g., 'openai/gpt-4', 'anthropic/claude-3-sonnet')",
      "examples": [
        "openai/gpt-4",
        "anthropic/claude-3-sonnet-20240229",
        "openai/gpt-3.5-turbo",
        "ollama/llama2"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Agent specialization description used by router for selection"
    },
    "instruction_chain": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered sequence of processing steps (strings, functions, or agentic steps)",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "String template processed by LLM (e.g., 'Analyze: {input}')"
          },
          {
            "type": "object",
            "description": "AgenticStepProcessor configuration for multi-hop reasoning",
            "required": ["type", "objective"],
            "properties": {
              "type": {
                "const": "agentic_step"
              },
              "objective": {
                "type": "string",
                "minLength": 10,
                "maxLength": 500,
                "description": "Goal for multi-hop reasoning"
              },
              "max_internal_steps": {
                "type": "integer",
                "minimum": 3,
                "maximum": 10,
                "default": 5,
                "description": "Maximum reasoning steps before completion"
              },
              "model": {
                "type": "string",
                "description": "Optional model override for reasoning steps"
              }
            }
          }
        ]
      }
    },
    "tools": {
      "type": "array",
      "description": "List of MCP tool names or local function names accessible to agent",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9_]+$"
      },
      "default": []
    },
    "history_config": {
      "type": "object",
      "description": "Per-agent history management configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether to include conversation history for this agent"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 100,
          "maximum": 16000,
          "default": 4000,
          "description": "Maximum tokens for conversation history"
        },
        "max_entries": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20,
          "description": "Maximum number of history entries"
        },
        "truncation_strategy": {
          "type": "string",
          "enum": ["oldest_first", "keep_last"],
          "default": "oldest_first",
          "description": "How to truncate when limits exceeded"
        },
        "include_types": {
          "type": "array",
          "description": "Filter history to specific entry types",
          "items": {
            "type": "string",
            "enum": ["user_input", "agent_output", "tool_call", "tool_result", "system_message"]
          }
        },
        "exclude_sources": {
          "type": "array",
          "description": "Exclude entries from specific sources",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of agent creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last agent update"
    }
  },
  "examples": [
    {
      "name": "researcher",
      "model": "openai/gpt-4",
      "description": "Research specialist with multi-hop reasoning and web search",
      "instruction_chain": [
        "Analyze research query: {input}",
        {
          "type": "agentic_step",
          "objective": "Research topic comprehensively",
          "max_internal_steps": 8
        },
        "Synthesize findings: {input}"
      ],
      "tools": ["web_search", "filesystem_read"],
      "history_config": {
        "enabled": true,
        "max_tokens": 8000,
        "truncation_strategy": "oldest_first"
      }
    },
    {
      "name": "terminal",
      "model": "openai/gpt-3.5-turbo",
      "description": "Command execution and system operations",
      "instruction_chain": ["{input}"],
      "tools": ["code_execution"],
      "history_config": {
        "enabled": false
      }
    }
  ]
}
